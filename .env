# ------------------------------------------
# 2. Configuración de Google Calendar
# ------------------------------------------
# NOTA: Debes ir a Google Cloud Console (https://console.cloud.google.com/)
# Crea un proyecto, habilita la "Google Calendar API", ve a "Credenciales", 
# crea una "Cuenta de Servicio" (Service Account), y genera una clave formato JSON.
# Descarga ese archivo .json y pon la ruta absoluta aquí.
# IMPORTANTE: Ve a tu Google Calendar personal, en la configuración de "Compartir con determinadas personas",
# añade el correo electrónico de la cuenta de servicio (termina en @tu-proyecto.iam.gserviceaccount.com) 
# y dale permisos para "Hacer cambios en eventos".
GOOGLE_CALENDAR_CREDENTIALS_PATH="/Volumes/Extreme SSD/qwen-agent-calendario-ee7b864aba88.json"
GOOGLE_CALENDAR_ID="educaleft@gmail.com"

