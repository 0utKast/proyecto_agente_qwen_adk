# ==========================================
# Configuración de Entorno (Ejemplo)
# ==========================================
# Renombra este archivo a .env y rellena tus datos.

# ------------------------------------------
# 1. Configuración de API de Notion (Opcional)
# ------------------------------------------
# Tutorial: https://www.notion.so/my-integrations
NOTION_API_KEY="tu_secret_de_notion_aqui"
# ID de la página o URL completa donde se guardarán los proyectos
NOTION_PARENT_PAGE_ID="tu_pagina_id_aqui"

# ------------------------------------------
# 2. Configuración de Google Calendar (Opcional)
# ------------------------------------------
# Ruta absoluta al archivo JSON de credenciales de Cuenta de Servicio
GOOGLE_CALENDAR_CREDENTIALS_PATH="/ruta/a/tu/cuenta-de-servicio.json"
# El email asociado a tu calendario de Google
GOOGLE_CALENDAR_ID="tu_email@gmail.com"

# ------------------------------------------
# 3. Configuración de Modelos y Local
# ------------------------------------------
# URL de Ollama (por defecto http://localhost:11434)
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# ------------------------------------------
# 4. WhatsApp Bridge (Twilio + ngrok)
# ------------------------------------------
# Obtén estos datos en https://console.twilio.com
TWILIO_ACCOUNT_SID="tu_account_sid_aqui"
TWILIO_AUTH_TOKEN="tu_auth_token_aqui"

# Número del Sandbox de Twilio (ej: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Puerto donde corre el Bridge (por defecto 8001)
BRIDGE_PORT=8001

# Tu número personal de WhatsApp autorizado (ej: whatsapp:+34600000000)
# Puedes poner varios separados por comas.
ALLOWED_PHONE_NUMBERS="whatsapp:+34000000000"

# Dominio estático gratuito de ngrok (MUY RECOMENDADO)
# Consíguelo en: https://dashboard.ngrok.com/cloud-edge/domains
NGROK_STATIC_DOMAIN="tu-dominio.ngrok-free.dev"
